# =============================================================================
# Environment Variables — New Naming Convention
# =============================================================================
# Preferred names use a clean `ARK_xxx` / `DB_xxx` prefix.
# Legacy `VOLC_xxx`, `DOUBAO_xxx`, `DUCKDB_xxx`, and bare `TTS_xxx` names are
# still supported as fallback but will emit deprecation warnings.
#
# Quick migration guide:
#   VOLC_ARK_API_KEY        → ARK_API_KEY
#   VOLC_ARK_API_URL        → ARK_BASE_URL
#   VOLC_ARK_VIDEO_API_KEY  → ARK_VIDEO_API_KEY
#   VOLC_TTS_API_KEY        → ARK_TTS_API_KEY
#   VOLC_TTS_API_URL        → ARK_TTS_API_URL
#   VOLC_TTS_APP_ID         → ARK_TTS_APP_ID
#   DUCKDB_ENABLED          → DB_ENABLED
#   DUCKDB_PATH             → DB_PATH
#   TTS_API_KEY             → ARK_TTS_API_KEY (use same value)
# =============================================================================

NODE_ENV=development
PORT=3000
GLOBAL_API_PREFIX=/api

POSTGRES_DB=tikstream_ai
POSTGRES_USER=tikstream
POSTGRES_PASSWORD=tikstream_password
DATABASE_URL=postgresql://tikstream:tikstream_password@localhost:5432/tikstream_ai?schema=public

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

KAFKA_BROKERS=localhost:9092

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_ASSETS=asset_slices

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=tikstream_minio
MINIO_SECRET_KEY=tikstream_minio_password
MINIO_BUCKET_NAME=tikstream-assets

# ---- ARK / AI 服务 --------------------
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
# (legacy) VOLC_ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

ARK_API_KEY=ark-1249de72-68c5-4737-8777-789f626d0a3b-c7bc9
# (legacy) VOLC_ARK_API_KEY=ark-1249de72-68c5-4737-8777-789f626d0a3b-c7bc9

# ---- 硅基流动 (SiliconFlow) ------------
SILICONFLOW_API_KEY=sk-onxfpomwarftotcnhrnrfxvbyebizqoljjevkgvagxarkhhs
SILICONFLOW_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct

ARK_VIDEO_API_KEY=ark-1249de72-68c5-4737-8777-789f626d0a3b-c7bc9
# (legacy) VOLC_ARK_VIDEO_API_KEY=ark-1249de72-68c5-4737-8777-789f626d0a3b-c7bc9

ARK_DOUBAO_PRO_ENDPOINT=ep-20260514115629-vhldw
# (legacy) VOLC_ARK_DOUBAO_PRO_ENDPOINT=ep-20260514115629-vhldw

ARK_DOUBAO_VIDEO_ENDPOINT=ep-20260514120705-pqv86
# (legacy) VOLC_ARK_DOUBAO_VIDEO_ENDPOINT=ep-20260514120705-pqv86

ARK_SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# (legacy) VOLC_ARK_SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3

ARK_SEEDANCE_MAX_CONCURRENCY=5
# (legacy) VOLC_ARK_SEEDANCE_MAX_CONCURRENCY=5

VOLC_ARK_DOUBAO_RATE_LIMIT_RPM=100

SCRIPT_LOCAL_FALLBACK_ENABLED=false

# ---- TTS 服务 -------------------------
ARK_TTS_API_KEY=
# (legacy) VOLC_TTS_API_KEY=
# (legacy) TTS_API_KEY=

ARK_TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts
# (legacy) VOLC_TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts

ARK_TTS_APP_ID=
# (legacy) VOLC_TTS_APP_ID=

TTS_PROVIDER=mock

# ---- 数据库 / 存储 --------------------
DB_ENABLED=
# (legacy) DUCKDB_ENABLED=

DB_PATH=
# (legacy) DUCKDB_PATH=

# ---- 前端 & Worker 端口 ----------------
ANALYTICS_MOCK_MODE=true

VITE_API_BASE_URL=http://localhost:3000
GPU_SLICING_WORKER_PORT=3101
REMOTION_RENDER_WORKER_PORT=3102
