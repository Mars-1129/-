        { "expr": "histogram_quantile(0.99, sum(rate(tikstream_http_request_duration_seconds_bucket[5m])) by (le, path))", "legendFormat": "P99 {{path}}" }
      ],
      "title": "HTTP 请求延迟 P50/P95/P99",
      "type": "timeseries"
    },
    {
