      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_route))", "legendFormat": "P50 {{http_route}}" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_route))", "legendFormat": "P95 {{http_route}}" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_server_duration_milliseconds_bucket[5m])) by (le, http_route))", "legendFormat": "P99 {{http_route}}" }
      ],
      "title": "响应延迟 P50/P95/P99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tikstream-prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "targets": [
        { "expr": "sum(rate(http_server_duration_milliseconds_count{http_status_code=~\"5..\"}[5m])) / sum(rate(http_server_duration_milliseconds_count[5m]))", "legendFormat": "5xx Error Rate" }
      ],
      "title": "错误率",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "tikstream-prometheus" },
