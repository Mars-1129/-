{
  "name": "tikstream-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=9 <10"
  },
  "pnpm": {
    "overrides": {
      "ioredis": "5.4.2",
      "remotion": "4.0.465",
      "@remotion/player": "4.0.465",
      "@remotion/renderer": "4.0.465",
      "@opentelemetry/api": "1.8.0"
    }
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @tikstream/server-gateway --filter @tikstream/web-client --filter @tikstream/gpu-slicing-worker --filter @tikstream/remotion-render-worker dev",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "jest --runInBand",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:style": "stylelint \"**/*.css\" --fix",
    "format": "prettier --check .",
    "openapi:lint": "tsx scripts/openapi-lint.ts",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma --accept-data-loss",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:comprehensive": "tsx prisma/comprehensive-seed.ts",
    "db:seed:enhanced": "tsx prisma/enhanced-seed.ts",
    "compose:up": "docker compose up --build -d",
    "compose:down": "docker compose down",
    "smoke": "tsx scripts/smoke.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.css": ["stylelint --fix", "prettier --write"]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "prettier": "^3.4.2",
    "prisma": "^5.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^37.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
